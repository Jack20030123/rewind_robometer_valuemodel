#!/usr/bin/env bash
#SBATCH --job-name=score_robo
#SBATCH --account=biyik_1165
#SBATCH --partition=main
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --time=4:00:00
#SBATCH --output=/project2/biyik_1165/haobaizh/rewind_robometer_valuemodel/logs/%x_%j.out
#SBATCH --error=/project2/biyik_1165/haobaizh/rewind_robometer_valuemodel/logs/%x_%j.err

set -e

source /apps/conda/miniforge3/25.11.0-1/etc/profile.d/conda.sh
conda activate /project2/biyik_1165/haobaizh/rewind_robometer_valuemodel/conda_envs/rewind

cd /project2/biyik_1165/haobaizh/rewind_robometer_valuemodel/metaworld_policy_training

which python
python --version

# Server URL: faucet-close env2 server on b17-15:8002
SERVER_URL=${1:-"http://b17-15.hpc.usc.edu:8002"}

python -u score_self_collected_robometer.py \
    --video_root ../self_collected_videos \
    --example_video_dir ../example_videos \
    --server_url "$SERVER_URL" \
    --output_dir score_output/self_collected_robometer

echo "=== DONE ==="
